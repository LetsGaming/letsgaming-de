# Minimal local-development env. Copy to `.env` at the repo root.
#
# The CMS API fails closed unless the CMS is "enabled" — that means a CMS_TOKEN or
# the GitHub OAuth pair. Setting CMS_TOKEN also makes SESSION_SECRET mandatory
# (assertSecureConfig refuses to boot with the shipped default, in dev too), which
# is what signs the session cookie the dev sign-in button mints.
#
# Generate a secret with:  openssl rand -hex 32

SESSION_SECRET=replace-me-with-a-long-random-value
CMS_TOKEN=any-local-value-you-like
CMS_ALLOWED_LOGIN=LetsGaming

# Where the API allows browser requests from (Nuxt dev runs on 4321).
WEB_ORIGIN=http://localhost:4321

# Where the BROWSER reaches the API. Without this the CMS calls resolve against
# the Nuxt origin (:4321) and 404 — it is baked into the client bundle at build.
PUBLIC_API_URL=http://localhost:8787

# Where SSR reaches the API when it can't open the store file directly.
API_URL=http://localhost:8787
