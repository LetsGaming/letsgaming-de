node_modules/
dist/

# Nuxt build output. `.nuxt` is regenerated by `nuxt prepare` on every install
# (it's the generated types and virtual modules); `.output` is the deployable
# Nitro build. Both are derived from source and would only ever create conflicts.
.nuxt/
.output/

.skills/
# runtime data + uploads live at the repo root only — anchored so it does NOT
# match source dirs like apps/web/src/data (which holds the committed fixture).
/data/
*.sqlite
*.sqlite-*
.env
.env.local
*.log
.DS_Store
