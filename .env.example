# ── Server (apps/server) ──────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
# The store + media ARE the archive — back these up (§10).
DB_PATH=./data/letsgaming.sqlite
MEDIA_DIR=./data/media
# Comma-separated allowed origins for the site (CORS). "*" allows all.
WEB_ORIGIN=http://localhost:4321

# GitHub source. Without a token the sync uses the deterministic MOCK source so
# the site still renders in dev. A classic PAT with read:user suffices.
GITHUB_USERNAME=LetsGaming
# GITHUB_TOKEN=ghp_xxx

# CMS auth. A signed session cookie (via GitHub OAuth) or a bearer token.
# SESSION_SECRET signs the cookie — set a long random string in production.
# SESSION_SECRET=change-me-to-a-long-random-string
# CMS_TOKEN=another-long-random-string
# CMS_ALLOWED_LOGIN=LetsGaming
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Contact relay (§9). Unset = the contact endpoint reports "not configured".
# Messages are relayed by email and never stored.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_FROM=no-reply@letsgaming.de
# CONTACT_TO=you@example.com

# ── Web (apps/web) ────────────────────────────────────────────────────────────
# SSR (server-side) reads the SiteView from here. Internal URL in Docker.
API_URL=http://localhost:8787
# Client-side (browser → API), baked into the CMS/client bundle at build time.
PUBLIC_API_URL=http://localhost:8787
