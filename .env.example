# Copy to .env. Everything in the two "required" blocks below is uncommented on
# purpose, it's the complete set needed to run and use the public homepage, and
# each has a working default. Everything under "Optional" is opt-in and stays
# commented until you turn that feature on.

# ── Server (apps/server), required ───────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
# The owner's timezone (IANA name). The default zone the playtime/listening day
# strips and the "when I play" heatmap are shown in; visitors can view their own
# local time from the site. Rarely changes for a single-user site — edit here and
# redeploy. Set on both the server and web services.
TZ=Europe/Berlin
# The store + media ARE the archive, back these up (§10).
DB_PATH=./data/letsgaming.sqlite
MEDIA_DIR=./data/media
# Comma-separated allowed origin(s) for the site (CORS). "*" is public read-only
# and DISABLES credentialed CORS (the CMS cookie won't be sent), set explicit
# origins for the CMS to work cross-origin.
WEB_ORIGIN=http://localhost:4321
# Set to true only when the server sits behind a trusted reverse proxy, so
# X-Forwarded-* is used for the real client IP. Leave false if directly exposed.
TRUST_PROXY=false
# Days of hourly analytics to keep before bundling into daily rows (storage cap).
RETAIN_HOURLY_DAYS=90
# GitHub source identity. Without a token (see Optional) the sync uses the
# deterministic MOCK source, so the site still renders.
GITHUB_USERNAME=LetsGaming

# ── Web (apps/web), required ──────────────────────────────────────────────────
# SSR resolves the SiteView by opening the store directly (read-only); API_URL is
# only the fallback for when the store file isn't reachable. The web process needs
# DB_PATH (to read the store) but NOT DISCORD_USER_ID: presence enablement is a CMS
# display flag resolved from the store, and the live Discord data is fetched by the
# browser from the server's /api/presence. The presence secret lives on the server
# alone. In Docker, pass DB_PATH to the web service (see docker-compose.yml).
API_URL=http://localhost:8787
# Client-side (browser → API), baked into the CMS/client bundle at build time.
PUBLIC_API_URL=http://localhost:8787
# The site's canonical origin. Every canonical URL, hreflang alternate, og:url,
# JSON-LD url, sitemap <loc> and the Sitemap: line in robots.txt is built from
# this, and SmartLink uses it to tell internal links from external ones. Wrong
# here and the site still renders perfectly while pointing search engines at the
# wrong domain.
PUBLIC_SITE_URL=https://letsgaming.de

# ── Optional (opt-in; leaving these unset is a valid, working config) ──────────

# Real GitHub data instead of the mock source. A classic PAT with read:user.
# No safe default exists, and an invalid value makes the sync fail, so only ever set
# this to a real token (that's why it stays commented).
# GITHUB_TOKEN=ghp_xxx

# CMS auth: uncommenting either CMS_TOKEN or the GitHub OAuth pair ENABLES the
# admin CMS. When enabled, a real cookie-signing secret is required: set
# SESSION_SECRET (recommended, e.g. `openssl rand -hex 32`), or a CMS_TOKEN
# doubles as one. The server refuses to start if the CMS is enabled with only an
# empty or default secret. Never reuse a value shown in this file.
# SESSION_SECRET=
# CMS_TOKEN=
# CMS_ALLOWED_LOGIN=LetsGaming
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Contact relay (§9). Unset = the contact endpoint reports "not configured".
# Messages are relayed by email and never stored.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_FROM=no-reply@letsgaming.de
# CONTACT_TO=you@example.com

# Traffic analytics (Top paths / referrers / browsers / OS / devices) are parsed
# from the reverse-proxy access log. Enable by setting BOTH:
#   ACCESS_LOG_DIR : the HOST directory that contains the log (mounted read-only)
#   ACCESS_LOG     : the log's path INSIDE the container, under /logs
# The directory is mounted, not the file, so a log that gets rotated or replaced
# (an rsync/scp that swaps the file) is picked up with no restart. The server then
# ingests it every 5 min (incremental + idempotent). The IP is never stored. Leave
# both unset to disable; the cookieless engagement stats still work.
#
# If your reverse proxy (e.g. NPMplus) runs on another box, sync the log into
# ACCESS_LOG_DIR first (scp on a timer). See docs/operations/analytics-ingestion.md.
# ACCESS_LOG_DIR=/opt/lg/logs
# ACCESS_LOG=/logs/access.log
# ANALYTICS_OWN_HOST=letsgaming.de   # optional; keeps your own domain out of Referrers

# Discord presence widget (Life → "Right now-ish"). The user id is public, not a
# secret. The SERVER fetches Lanyard, applies the allow-list, and exposes only the
# allowed result at /api/presence, and the browser never sees disabled activities.
# Which categories show is edited in the CMS (/admin → Presence), not here.
# Join the Lanyard Discord (discord.gg/lanyard) once so your presence is exposed.
# DISCORD_USER_ID=272402865874534400

# Wakapi (coding time by language), LAN-only, never exposed to the internet.
# The sync worker calls it server-side, so a private address is enough. Both
# required to activate; otherwise the module shows nothing (mock only in dev).
# WAKAPI_URL=http://192.168.2.20:3000
# WAKAPI_KEY=

# RAWG (video game database), resolves game names to cover art + genre for the
# playtime module. Free key at rawg.io/apidocs. Optional — without it the
# recently-played shelf shows monograms and no genre.
# RAWG_API_KEY=

# ── Orphaned ──────────
# The following are no longer used, but remain here for reference. They can be removed at any time.

# Steam is parked for now, we will revisit it later
# STEAM_API_KEY=
# STEAM_USER_ID=