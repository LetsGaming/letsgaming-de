{
  "name": "letsgaming-de",
  "version": "2.0.0",
  "private": true,
  "description": "Personal homepage for Domenic (@LetsGaming) \u2014 data-driven, self-updating, small-CMS.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm lint:nav && pnpm lint:tokens && pnpm -r --filter=./packages/* build && pnpm --filter=@lg/server build && pnpm --filter=@lg/web build",
    "dev": "pnpm --parallel --filter=@lg/server --filter=@lg/web dev",
    "dev:server": "pnpm --filter=@lg/server dev",
    "dev:web": "pnpm --filter=@lg/web dev",
    "sync": "pnpm --filter=@lg/server sync",
    "lint:nav": "pnpm --filter=@lg/core lint:nav",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "analytics": "pnpm --filter=@lg/server analytics",
    "lint:tokens": "pnpm --filter=@lg/web lint:tokens"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
