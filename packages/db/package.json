{
  "name": "@lg/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SQLite store: schema + repositories. The single source of truth that accumulates source snapshots (the archive) and upserts the current view.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/schema.sql"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/schema.sql','dist/schema.sql')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./src/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@lg/core": "workspace:^"
  }
}