{
  "name": "@lg/sources",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pluggable data-source adapters. Each implements the Source contract; adding a source is one adapter + one registration. GitHub only at launch.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./src/*.test.ts"
  },
  "dependencies": {
    "@lg/core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
