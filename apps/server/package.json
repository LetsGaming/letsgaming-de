{
  "name": "@lg/server",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify server: read API + CMS API + GitHub OAuth + the sync worker host.",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "sync": "tsx src/sync/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analytics": "tsx src/analytics/cli.ts",
    "test": "node --test --import tsx \"tests/**/*.test.ts\"",
    "analytics:reclassify": "tsx src/analytics/reclassify-cli.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9",
    "@lg/core": "workspace:^",
    "@lg/db": "workspace:^",
    "@lg/sources": "workspace:^",
    "fastify": "^5.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "sharp": "^0.33"
  },
  "devDependencies": {
    "@types/node": "^26",
    "@types/nodemailer": "^8",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
