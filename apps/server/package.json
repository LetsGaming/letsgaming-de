{
  "name": "@lg/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify server: read API + CMS API + GitHub OAuth + the sync worker host.",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "sync": "tsx src/sync/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analytics": "tsx src/analytics/cli.ts",
    "test": "node --test --import tsx \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9",
    "@lg/core": "workspace:^",
    "@lg/db": "workspace:^",
    "@lg/sources": "workspace:^",
    "fastify": "^5.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6",
    "sharp": "^0.35"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}