---
import CmsApp from "../components/cms/CmsApp.vue";
import Layout from "../layouts/Layout.astro";

// Static shell — auth and data all happen client-side against the API, so the
// server never renders private content. `client:only` keeps it out of SSR.
export const prerender = true;
---

<Layout title="CMS — letsgaming.de">
  <CmsApp client:only="vue" />
</Layout>
