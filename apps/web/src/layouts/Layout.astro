---
import "@fontsource/fredoka/400.css";
import "@fontsource/fredoka/500.css";
import "@fontsource/fredoka/600.css";
import "@fontsource/fredoka/700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/tokens.css";
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  locale?: "en" | "de";
  /** Only the SSR index reacts to ?lang; prerendered pages opt out of the redirect. */
  localeAware?: boolean;
}
const {
  title = "Domenic — web dev & tinkerer",
  description = "Personal homepage of Domenic (@LetsGaming) — full-time web developer in Germany. Clean interfaces by day; plant sensors and LED strips by night.",
  locale = "en",
  localeAware = false,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#8b5cf6" />
    <meta name="theme-color" content="#8b5cf6" />
    <!-- Fonts are self-hosted (imported in the frontmatter) — no third-party
         request, so no consent banner burden. -->
    <!-- No-flash theme: set data-theme before first paint from a stored choice,
         falling back to the OS preference. Runs synchronously, tiny, inline. -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var theme =
            saved === "light" || saved === "dark"
              ? saved
              : matchMedia("(prefers-color-scheme: light)").matches
                ? "light"
                : "dark";
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
    <!-- No-flash locale: if the URL carries no explicit ?lang but the visitor
         previously chose one that differs from what the server rendered, redirect
         once so the whole page is server-rendered in their language. Cookieless
         (localStorage), guarded against loops (only when ?lang is absent). Only on
         the locale-aware index — prerendered pages ignore ?lang. -->
    {
      localeAware && (
        <script is:inline>
          {`(function () {
            try {
              var url = new URL(location.href);
              if (url.searchParams.has("lang")) return;
              var saved = localStorage.getItem("lang");
              if ((saved === "en" || saved === "de") && saved !== document.documentElement.lang) {
                url.searchParams.set("lang", saved);
                location.replace(url.toString());
              }
            } catch (e) {}
          })();`}
        </script>
      )
    }

    <!-- Client-side navigation: soft-swap same-origin pages instead of a full
         document reload, so switching area tabs no longer refetches and repaints
         the whole site. Islands re-hydrate on swap; the <html> element (and its
         data-theme) persists, so the theme doesn't flash. -->
    <ClientRouter />

    <!-- Docs drawer, delegated on `document` so it keeps working across view
         transitions. A per-page inline script wouldn't: soft-navigating *into* a
         docs page swaps the markup in without re-running its inline scripts, so
         the buttons would have no handlers. Delegation binds once, here, and
         resolves the current elements at click time. No-ops off the docs pages. -->
    <script is:inline>
      (function () {
        function el(sel) {
          return document.querySelector(sel);
        }
        function setOpen(open) {
          var nav = document.getElementById("doc-nav");
          var scrim = el("[data-doc-scrim]");
          if (nav) nav.classList.toggle("open", open);
          if (scrim) scrim.classList.toggle("show", open);
          document.body.classList.toggle("nav-locked", open);
        }
        document.addEventListener("click", function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          if (t.closest("[data-doc-open]")) return setOpen(true);
          if (t.closest("[data-doc-close]") || t.closest("[data-doc-scrim]")) return setOpen(false);
          var nav = document.getElementById("doc-nav");
          if (nav && nav.contains(t) && t.closest("a")) setOpen(false);
        });
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") setOpen(false);
        });
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
